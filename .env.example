# Required — LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_API_BASE_URL=

# Required — shared secrets
INIT_ADMIN_TOKEN=change-me
INTERNAL_API_KEY=change-me
WOT_RUNTIME_REGISTRY_TOKEN=change-me
WOT_RUNTIME_API_TOKEN=change-me

# Optional — embedding / semantic search
OPENAI_EMBEDDING_API_BASE_URL=
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_MODEL=mxbai-embed-large

# Optional — specialist agent runtime
SPECIALIST_AGENT_TIMEOUT_SECONDS=60

# Optional — Docker MCP Gateway integration
# Dynamic server management tools (mcp-find/mcp-add) are controlled by Docker
# feature flags on the Docker host: `docker mcp feature enable dynamic-tools`.
DOCKER_MCP_GATEWAY_URL=http://docker-mcp-gateway:8811/mcp
