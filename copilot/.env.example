# LLM Configuration
# One key only. Required by the app and underlying libraries.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1 # Optional: Override for custom endpoints

# MCP / WoT Registry
WOT_REGISTRY_URL=http://wot-registry:8000/mcp
WOT_REGISTRY_TOKEN=              # API key for registry authentication

# Code Executor
CODE_EXECUTOR_TIMEOUT_SECONDS=330

# Logging
LOG_LEVEL=INFO

# Security
INTERNAL_API_KEY=your-secure-internal-api-key-here
